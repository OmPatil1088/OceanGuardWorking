{
  "name": "oceanguard-api",
  "version": "1.0.0",
  "description": "Government-Grade Disaster Management API",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.{js,json}\"",
    "migrate": "node scripts/migrate.js",
    "migrate:reset": "node scripts/migrate-reset.js",
    "seed": "node scripts/seed.js",
    "audit": "npm audit",
    "security:check": "npm audit fix",
    "performance:test": "artillery run load-test.yml",
    "health:check": "curl http://localhost:5000/health",
    "db:test": "node scripts/db-test.js",
    "monitor": "pm2 monitor"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "firebase": "^12.12.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.10.0",
    "redis": "^4.6.0",
    "socket.io": "^4.6.0",
    "stripe": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  }
}
