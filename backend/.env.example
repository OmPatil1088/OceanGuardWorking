# 🔐 Environment Configuration Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ========================================
# Server Configuration
# ========================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
WORKERS=4

# ========================================
# Database
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oceanguard_prod
DB_USER=oceanguard_admin
DB_PASSWORD=your_secure_password_here
DB_SSL=true
DB_POOL_MIN=10
DB_POOL_MAX=100

# ========================================
# Cache (Redis)
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
CACHE_TTL=3600

# ========================================
# Authentication (JWT)
# ========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRE=7d

# ========================================
# Security
# ========================================
BCRYPT_ROUNDS=12
CORS_ORIGIN=https://yourdomain.gov.in,https://api.yourdomain.gov.in
HELMET_ENABLED=true
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000

# ========================================
# APIs & Integrations
# ========================================
OPENWEATHER_API_KEY=your_api_key
IMD_API_KEY=your_imd_api_key
GOOGLE_MAPS_API_KEY=your_maps_api_key
TWILIO_ACCOUNT_SID=your_account_id
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# ========================================
# Email Configuration
# ========================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.gov.in

# ========================================
# Logging
# ========================================
LOG_LEVEL=info
LOG_FORMAT=combined
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# ========================================
# AWS Services (if using AWS)
# ========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=oceanguard-bucket
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:xxxx

# ========================================
# Feature Flags
# ========================================
ENABLE_AI_PREDICTIONS=true
ENABLE_COMMUNITY_VERIFICATION=true
ENABLE_SMS_ALERTS=true
ENABLE_EMAIL_ALERTS=true
ENABLE_PUSH_NOTIFICATIONS=true

# ========================================
# Government Integration (Optional)
# ========================================
NREGA_API_URL=https://nrega.gov.in/api
GST_API_URL=https://gst.gov.in/api
AADHAR_API_URL=https://aadhar.gov.in/api

# ========================================
# Monitoring & Metrics
# ========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# ========================================
# Security Headers
# ========================================
STRICT_TRANSPORT_SECURITY=max-age=31536000
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
CONTENT_SECURITY_POLICY="default-src 'self'"
